    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch VectorStore",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/vectorstore/",
            "env": {
                "VECTORSTORE_GRPC_SERVER_PORT": "9091",
                "VECTORSTORE_GRPC_GATEWAY_PORT": "8080",
                "FASTEMBED_BASEURL": "http://localhost:8000",
                "QDRANT_HOST": "localhost",
                "QDRANT_GRPC_PORT": "6334",
                "QDRANT_COLLECTION_NAME": "collection",
                "QDRANT_VECTOR_SIZE": "1024",
            },
        }
    ]
}